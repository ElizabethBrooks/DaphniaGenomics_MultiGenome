// Part of nextflow config describing resource requirements for EGAPx processes
// We rely on labels to define 3 tiers of processes - default, big, and huge.
// Make sure that executor you use supports job memory and CPU requirements
//To be set based on the environment where Nextflow is run
params.threads = 15
params.nodes = 15
params.num_cpus_per_node = 90

process {
 
}
process {
    memory = 120.GB
    cpus = 15
    ext.align_mem = '120'
    time = 6.h
    errorStrategy = 'retry'
    maxRetries = 3

    withLabel: 'long_job' {
        time = 336.h
    }
    withLabel: 'small_mem' { 
        memory = 120.GB
    }
    withLabel: 'med_mem' {
        memory = 120.GB
    }
    withLabel: 'large_mem' { 
        memory = 128.GB
    }
    withLabel: 'single_cpu' {
        ext {
            split_jobs = 1
            threads = 1
        }
        cpus = 1 
    }
    withLabel: 'multi_cpu' {
        ext {
            split_jobs = 1
            threads = params.threads
        }
        cpus = params.threads
    }
    withLabel: 'multi_node' { 
        ext {
            split_jobs = params.nodes
            threads = params.threads
        }
        cpus = params.threads
    }
    withLabel: 'gpx_submitter' {
        ext {
            split_jobs = params.nodes
            threads = 15
        }
        cpus = 15
    }
}

profiles {

    stubrun {
        
        process {
            memory = 120.GB
            cpus = 15
            time = 6.h

            withLabel: 'big_job' {
                memory = 120.GB
                cpus = 15
            }

            withLabel: 'huge_job' {
                memory = 120.GB
                cpus = 15
            }

            withLabel: 'long_job' {
                time = 6.h
            }
        }
    }

}
